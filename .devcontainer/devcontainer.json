{
	"name": "HEIG-VD UPInfo Course Development Container",
	"image": "mcr.microsoft.com/devcontainers/typescript-node:24-trixie",
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:4.0.0": {
			"moby": false
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"astro-build.astro-vscode",
				"DavidAnson.vscode-markdownlint",
				"esbenp.prettier-vscode",
				"GitHub.copilot",
				"jebbs.plantuml",
				"redhat.vscode-yaml",
				"marp-team.marp-vscode",
				"streetsidesoftware.code-spell-checker",
				"streetsidesoftware.code-spell-checker-french",
				"tomoki1207.pdf"
			],
			"mcp": {
				"servers": {
					"Astro docs": {
						"type": "http",
						"url": "https://mcp.docs.astro.build/mcp"
					}
				}
			}
		}
	},
	// Ports to expose on the container's network host
	"forwardPorts": [4321],
	"portsAttributes": {
		"8080": {
			"label": "Astro's development server"
		}
	}
}
