---
import { Aside, Icon } from "@astrojs/starlight/components";
---

<Aside type="note" icon="rocket" title="J'ai terminé ce contenu !">
	<label class="progress-label" for="page-progress-checkbox">
		<input
			id="page-progress-checkbox"
			type="checkbox"
			data-umami-event="progress"
			data-umami-event-value="toggle"
		/>
		<span>
			Félicitations ! Cochez cette case lorsque vous avez terminé ce contenu.
		</span>
	</label>
</Aside>

<template id="progress-marker-template">
	<span class="progress-marker" aria-hidden="true">
		<Icon name="approve-check-circle" />
	</span>
</template>

<style>
	.progress-label {
		padding-top: 0.5rem;
		margin: 0.5rem 0;
		display: inline-flex;
		align-items: center;
		gap: 1rem;
	}

	.progress-label input[type="checkbox"] {
		width: 1.1rem;
		height: 1.1rem;
		cursor: pointer;
	}

	:global(#starlight__sidebar li.has-progress-marker) {
		position: relative;
	}

	:global(#starlight__sidebar li.has-progress-marker > a) {
		padding-inline-start: calc(
			var(--sl-sidebar-item-padding-inline, 0.5rem) + 1.4rem
		);
	}

	:global(#starlight__sidebar li .progress-marker) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1rem;
		height: 1rem;
		position: absolute;
		top: 50%;
		transform: translateY(-50%) translateX(50%);
		color: var(--sl-color-green-high);
		flex-shrink: 0;
		pointer-events: none;
	}

	:global(#starlight__sidebar li > a[aria-current="page"] + .progress-marker) {
		color: var(--sl-color-text-invert);
	}
</style>

<script is:inline>
	const STORAGE_KEY = "starlight-progress-v1";
	const markerTemplate = document.getElementById("progress-marker-template");

	function normalizePath(pathname) {
		if (!pathname) {
			return "/";
		}

		if (pathname.length > 1 && pathname.endsWith("/")) {
			return pathname.slice(0, -1);
		}

		return pathname;
	}

	function readState() {
		try {
			const raw = localStorage.getItem(STORAGE_KEY);
			if (!raw) {
				return {};
			}

			const parsed = JSON.parse(raw);

			return parsed && typeof parsed === "object" ? parsed : {};
		} catch {
			return {};
		}
	}

	function saveState(state) {
		localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
	}

	function applySidebarProgress(state) {
		const links = document.querySelectorAll("#starlight__sidebar a[href]");

		links.forEach((link) => {
			let targetPath = "";
			try {
				targetPath = normalizePath(
					new URL(link.href, window.location.origin).pathname,
				);
			} catch {
				return;
			}

			const done = Boolean(state[targetPath]);
			const item = link.closest("li");
			if (!(item instanceof HTMLElement)) {
				return;
			}

			const marker = item.querySelector(":scope > .progress-marker");

			if (done && !marker) {
				if (!(markerTemplate instanceof HTMLTemplateElement)) {
					return;
				}

				const badge = markerTemplate.content.firstElementChild?.cloneNode(true);

				if (!(badge instanceof HTMLElement)) {
					return;
				}

				item.classList.add("has-progress-marker");
				link.insertAdjacentElement("afterend", badge);
			}

			if (!done && marker) {
				marker.remove();
				item.classList.remove("has-progress-marker");
			}
		});
	}

	document.addEventListener(
		"DOMContentLoaded",
		() => {
			const checkbox = document.getElementById("page-progress-checkbox");
			const pagePath = normalizePath(window.location.pathname);
			const state = readState();

			applySidebarProgress(state);

			if (!(checkbox instanceof HTMLInputElement)) {
				return;
			}

			checkbox.checked = Boolean(state[pagePath]);

			checkbox.addEventListener("change", () => {
				const nextState = readState();

				if (checkbox.checked) {
					nextState[pagePath] = true;
					umami.trackEvent("progress", "mark-complete");
				} else {
					delete nextState[pagePath];
					umami.trackEvent("progress", "mark-incomplete");
				}

				saveState(nextState);
				applySidebarProgress(nextState);
			});
		},
		{ once: true },
	);
</script>
